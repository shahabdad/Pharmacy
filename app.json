{
  "expo": {
    "name": "Medicare",
    "slug": "Medicare",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "medicare",
    "icon": "./assets/images/Medi.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Medi.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medicare.app",
      "icon": "./assets/images/Medi.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Medi.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.medicare.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/Medi.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}