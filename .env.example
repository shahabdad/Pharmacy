# ─── Firebase Configuration ───────────────────────────────────────────────────
# Rename this file to .env and replace the values with your own Firebase project
# credentials from: https://console.firebase.google.com
#
# How to find these values:
#   1. Go to Firebase Console → your project → Project Settings (gear icon)
#   2. Scroll to "Your apps" → select your web/Expo app
#   3. Copy the firebaseConfig object values below

EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://pharmacy-8086d-default-rtdb.firebaseio.com/

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# Create an Android OAuth Client ID with your app's SHA-1 fingerprint
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=796858068178-pmk6397vpgap5laluuqiocmkd488g6dj.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=796858068178-0svnct6c3a1pdoecftn9l0bish57l9ji.apps.googleusercontent.com

# ─── WhatsApp Configuration ───────────────────────────────────────────────────
# Shop WhatsApp number for customer support (include country code)
EXPO_PUBLIC_SHOP_WHATSAPP=+923191796621

# ─── Admin Configuration ──────────────────────────────────────────────────────
# Admin email addresses (comma-separated)
# Users with these emails will be automatically assigned admin role
# Example: admin1@gmail.com,admin2@gmail.com
EXPO_PUBLIC_ADMIN_EMAILS=shahabdad50@gmail.com,shhhbdad@gmail.com
